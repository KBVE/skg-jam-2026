; Engine configuration file.
; Godot 4.7 project for the skg-jam-2026 web harness.
; Rendering is forced to GL Compatibility (WebGL2) for web export.

config_version=5

[application]

config/name="skg-jam-2026-godot"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

; GECS singleton. Added manually (not via the editor plugin) so the headless
; export includes it. If you enable the GECS editor plugin later, remove this
; line — the plugin registers its own ECS autoload and would conflict.
ECS="*res://addons/gecs/ecs/ecs.gd"
JsBridge="*res://scripts/JsBridge.gd"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
